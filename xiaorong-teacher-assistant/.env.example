# Database and message broker credentials. Replace all placeholder values before deployment.
MYSQL_ROOT_PASSWORD=replace-with-a-strong-password
RABBITMQ_DEFAULT_USER=replace-with-a-username
RABBITMQ_DEFAULT_PASS=replace-with-a-strong-password

# AI providers. Leave blank to use the application's configured mock/default behavior.
BAILIAN_API_KEY=
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
ONEAPI_API_KEY=

# Baidu OCR for uploaded resume images and scanned PDFs.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
XIAORONG_INTERVIEW_OCR_ENABLED=false

# Encryption key for stored AI provider credentials.
XIAORONG_AI_SECRET_MASTER_KEY=